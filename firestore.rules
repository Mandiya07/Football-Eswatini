rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isLeagueAdmin() {
      return isAuthenticated() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'league_admin';
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'] ||
          (request.auth.token.email == "siphom.yati@gmail.com" && request.auth.token.email_verified == true));
    }

    function isEFAAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'efa_admin' || isAdmin());
    }

    // ===============================================================
    // Rules
    // ===============================================================
    
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isOwner(userId) || isAdmin();
    }

    match /competitions/{compId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /news/{newsId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cups/{cupId} {
      allow read: if true;
      allow write: if isAdmin() || isLeagueAdmin();
    }

    match /hybrid_tournaments/{tournamentId} {
      allow read: if true;
      allow write: if isAdmin() || isLeagueAdmin();
    }

    match /efa_communications/{commId} {
      allow read: if true;
      allow write: if isEFAAdmin();
    }

    match /efa_stats/{statId} {
      allow read: if true;
      allow write: if isEFAAdmin();
    }

    match /crm_leads/{leadId} {
      allow read, write: if isAdmin();
    }

    match /{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
